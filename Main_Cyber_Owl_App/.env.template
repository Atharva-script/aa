# ============================================
# CYBER OWL - Production Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: Never commit .env to version control!

# ============================================
# EMAIL CONFIGURATION (Required for Alerts)
# ============================================
# Gmail Configuration:
# 1. Enable 2-factor authentication on your Google account
# 2. Generate an "App Password" from: https://myaccount.google.com/apppasswords
# 3. Use that app password below (NOT your regular Gmail password)

# Sender Email (Gmail account that sends alerts)
MAIL_USERNAME=your-sender-email@gmail.com

# Gmail App Password (16 characters, spaces optional)
MAIL_PASSWORD=your-app-password-here

# Recipient Email (Parent's email to receive alerts)
ALERT_EMAIL_TO=parent-email@example.com

# Example Configuration:
# MAIL_USERNAME=cyberowl.alerts@gmail.com
# MAIL_PASSWORD=abcd efgh ijkl mnop
# ALERT_EMAIL_TO=parent@example.com

# ============================================
# DATABASE CONFIGURATION (Required)
# ============================================
# MongoDB Atlas (Recommended for Production)
# Get your connection string from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cyberowl?retryWrites=true&w=majority

# Local MongoDB (For Development/Testing)
# MONGO_URI=mongodb://localhost:27017/cyberowl

# MongoDB Database Name (Optional - defaults to 'cyberowl')
# MONGO_DB_NAME=cyberowl

# ============================================
# SERVER CONFIGURATION (Optional)
# ============================================
# Server Host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
SERVER_HOST=0.0.0.0

# Server Port
SERVER_PORT=5000

# Flask Secret Key (Generate a random string for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Debug Mode (NEVER enable in production!)
DEBUG_MODE=False

# ============================================
# SECURITY CONFIGURATION (Optional)
# ============================================
# CORS Allowed Origins (comma-separated, * for all - not recommended for production)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Session Timeout (in seconds, default: 86400 = 24 hours)
# SESSION_TIMEOUT=86400

# Maximum Login Attempts (before temporary lockout)
# MAX_LOGIN_ATTEMPTS=5

# ============================================
# DETECTION CONFIGURATION (Optional)
# ============================================
# Enable/Disable Detection Modules
# ENABLE_AUDIO_DETECTION=True
# ENABLE_SCREEN_DETECTION=True

# Detection Sensitivity (0.0 to 1.0, higher = more sensitive)
# ABUSE_THRESHOLD=0.7
# NUDITY_THRESHOLD=0.6

# ============================================
# LOGGING CONFIGURATION (Optional)
# ============================================
# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log File Path (leave empty to disable file logging)
# LOG_FILE=logs/cyberowl.log

# ============================================
# ADVANCED CONFIGURATION (Optional)
# ============================================
# Socket.IO Configuration
# SOCKETIO_PING_TIMEOUT=60
# SOCKETIO_PING_INTERVAL=25

# Upload Folder Path
# UPLOAD_FOLDER=uploads

# Maximum Upload Size (in MB)
# MAX_UPLOAD_SIZE=10
